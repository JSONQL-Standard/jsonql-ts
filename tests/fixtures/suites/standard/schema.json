{
  "users": {
    "fields": {
      "id": { "type": "integer", "primary": true },
      "name": { "type": "string" },
      "email": { "type": "string", "unique": true },
      "status": { "type": "string" },
      "age": { "type": "integer" },
      "deleted_at": { "type": "timestamp", "nullable": true }
    },
    "relations": {
      "posts": { "type": "hasMany", "target": "posts", "foreignKey": "user_id" },
      "orders": { "type": "hasMany", "target": "orders", "foreignKey": "user_id" }
    }
  },
  "posts": {
    "fields": {
      "id": { "type": "integer", "primary": true },
      "user_id": { "type": "integer" },
      "title": { "type": "string" },
      "views": { "type": "integer" },
      "published": { "type": "boolean" }
    },
    "relations": {
      "author": { "type": "belongsTo", "target": "users", "foreignKey": "user_id" },
      "comments": { "type": "hasMany", "target": "comments", "foreignKey": "post_id" }
    }
  },
  "comments": {
    "fields": {
      "id": { "type": "integer", "primary": true },
      "post_id": { "type": "integer" },
      "user_id": { "type": "integer" },
      "content": { "type": "string" },
      "approved": { "type": "boolean" }
    },
    "relations": {
      "post": { "type": "belongsTo", "target": "posts", "foreignKey": "post_id" },
      "author": { "type": "belongsTo", "target": "users", "foreignKey": "user_id" }
    }
  },
  "products": {
    "fields": {
      "id": { "type": "string", "primary": true },
      "name": { "type": "string" },
      "category": { "type": "string" },
      "price": { "type": "number" },
      "in_stock": { "type": "boolean" },
      "rating": { "type": "number" }
    }
  },
  "orders": {
    "fields": {
      "id": { "type": "string", "primary": true },
      "user_id": { "type": "integer" },
      "total": { "type": "number" },
      "status": { "type": "string" },
      "created_at": { "type": "timestamp" }
    },
    "relations": {
      "user": { "type": "belongsTo", "target": "users", "foreignKey": "user_id" }
    }
  }
}
