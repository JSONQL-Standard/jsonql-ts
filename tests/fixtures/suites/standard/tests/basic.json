[
  {
    "id": "parse-001",
    "description": "Basic fields selection",
    "schema": {
      "fields": {
        "id": { "type": "integer" },
        "name": { "type": "string" }
      }
    },
    "query": {
      "version": "1.0",
      "fields": ["id", "name"]
    },
    "valid": true
  },
  {
    "id": "parse-002",
    "description": "Where clause with eq operator",
    "schema": {
      "fields": {
        "status": { "type": "string" }
      }
    },
    "query": {
      "version": "1.0",
      "where": {
        "status": { "eq": "active" }
      }
    },
    "valid": true
  },
  {
    "id": "parse-003",
    "description": "Valid: Missing version (defaults to latest)",
    "schema": {
      "fields": {
        "id": { "type": "integer" }
      }
    },
    "query": {
      "fields": ["id"]
    },
    "valid": true
  },
  {
    "id": "parse-004",
    "description": "Invalid: Empty fields array",
    "schema": {
      "fields": {
        "id": { "type": "integer" }
      }
    },
    "query": {
      "version": "1.0",
      "fields": []
    },
    "valid": false,
    "expectedError": "Fields array cannot be empty"
  }
]
