{
  "name": "@jsonql-standard/jsonql-ts",
  "version": "1.0.1",
  "description": "Official Node.js SDK for JSONQL with support for Express, Fastify, and NestJS",
  "license": "MIT",
  "author": "JSONQL Standard",
  "homepage": "https://jsonql.org/sdk/typescript/",
  "repository": {
    "type": "git",
    "url": "https://github.com/JSONQL-Standard/jsonql-ts.git"
  },
  "bugs": {
    "url": "https://github.com/JSONQL-Standard/jsonql-ts/issues"
  },
  "keywords": [
    "jsonql",
    "query",
    "sql",
    "mongodb",
    "orm",
    "express",
    "fastify",
    "nestjs",
    "transpiler"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build:lib && npm run build:cli",
    "build:lib": "tsc",
    "build:cli": "tsc -p tsconfig.cli.json",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "jest",
    "bench": "tsx benchmark/parser.ts && tsx benchmark/transpiler.ts"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/testing": "^11.1.9",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/pg": "^8.15.6",
    "@types/sqlite3": "^3.1.11",
    "@types/supertest": "^6.0.2",
    "@types/yargs": "^17.0.32",
    "benchmark": "^2.1.4",
    "express": "^4.18.2",
    "fastify": "^4.29.1",
    "fastify-plugin": "^5.1.0",
    "jest": "^29.7.0",
    "pg": "^8.16.3",
    "prettier": "^3.7.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sqlite": "^5.1.1",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "typescript": "^5.3.3",
    "yargs": "^17.7.2"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "mysql2": "^3.16.0"
  },
  "optionalDependencies": {
    "pg": "^8.16.3",
    "sqlite3": "^5.1.7"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "express": "^4.0.0",
    "fastify": "^4.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  }
}
